@inject IJSRuntime JS
@implements IAsyncDisposable

<div class="emulator-wrapper">
    <div id="game"></div>
</div>

@code {
    [Parameter, EditorRequired] public string Core { get; set; } = "";
    [Parameter, EditorRequired] public string RomUrl { get; set; } = "";
    [Parameter] public string? BiosUrl { get; set; }

    private IJSObjectReference? _module;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        _module = await JS.InvokeAsync<IJSObjectReference>(
            "import", "./js/emulator-interop.js");

        await _module.InvokeVoidAsync("initEmulator", Core, RomUrl, BiosUrl ?? "");
    }

    public async ValueTask DisposeAsync()
    {
        if (_module is not null)
        {
            await _module.InvokeVoidAsync("destroyEmulator");
            await _module.DisposeAsync();
        }
    }
}
