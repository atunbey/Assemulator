@inherits LayoutComponentBase

<MudThemeProvider Theme="_theme" IsDarkMode="true" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<div class="assemulator-shell">
    <nav class="top-nav">
        <a href="/" class="nav-logo">ASSEMULATOR</a>
        <div class="nav-links">
            <a href="/">Home</a>
        </div>
    </nav>

    <main class="main-content">
        @Body
    </main>
</div>

@code {
    private readonly MudTheme _theme = new()
    {
        PaletteLight = new PaletteLight
        {
            Primary = "#e50914",
            Background = "#141414",
            Surface = "#1f1f1f",
            AppbarBackground = "#000000e6",
            DrawerBackground = "#141414",
            TextPrimary = "#ffffff",
            TextSecondary = "#b3b3b3",
        },
        PaletteDark = new PaletteDark
        {
            Primary = "#e50914",
            Background = "#141414",
            Surface = "#1f1f1f",
            AppbarBackground = "#000000e6",
            DrawerBackground = "#141414",
            TextPrimary = "#ffffff",
            TextSecondary = "#b3b3b3",
        }
    };
}
