#!/bin/bash

set -eu

source _common.sh
source /usr/share/yunohost/helpers

domain=$(ynh_app_setting_get --app=$app --key=domain)
path_url=$(ynh_app_setting_get --app=$app --key=path)
app_port=$(ynh_app_setting_get --app=$app --key=port)
image=$(ynh_app_setting_get --app=$app --key=image)

[ -n "$domain" ] || ynh_die --message="Missing domain setting"
[ -n "$path_url" ] || ynh_die --message="Missing path setting"
[ -n "$app_port" ] || ynh_die --message="Missing port setting"
[ -n "$image" ] || ynh_die --message="Missing image setting"

ynh_script_progression --message="Ensuring Docker and Compose are available..."
ynh_exec_warn_less ynh_install_app_dependencies docker.io docker-compose-plugin

if [ -f "$final_path/docker-compose.yml" ]; then
    ynh_script_progression --message="Stopping running container before restore..."
    ynh_exec_warn_less docker compose -f "$final_path/docker-compose.yml" down || true
fi

ynh_script_progression --message="Restoring Assemulator files..."
ynh_safe_rm "$final_path"
mkdir -p "$final_path"
ynh_restore_file --origin_path="$final_path"

ynh_script_progression --message="Restoring reverse proxy configuration..."
ynh_add_nginx_config

ynh_script_progression --message="Restarting container..."
ynh_exec_warn_less docker compose -f "$final_path/docker-compose.yml" pull
ynh_exec_warn_less docker compose -f "$final_path/docker-compose.yml" up -d

ynh_script_progression --message="Reloading nginx..."
ynh_systemctl --service=nginx --action=reload
